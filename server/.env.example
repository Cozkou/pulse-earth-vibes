# Copy to .env and fill in. Used by server/index.js (Spotify, Claude, Luffa, YouTube).
# Luffa uses polling: set LUFFA_BOT_SECRET (Robot Key from Luffa dashboard).
# Crystal Ball: set YOUTUBE_API_KEY for in-browser music (Google Cloud Console, enable YouTube Data API v3).

LUFFA_BOT_SECRET=
YOUTUBE_API_KEY=
